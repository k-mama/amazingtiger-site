# Public — safe to expose in browser code
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — Cloudflare Pages Functions only. Never import into client components.
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
AI_API_KEY=
PAYMENT_SECRET_KEY=

# Email delivery for functions/api/consultation.ts AND functions/api/order-notify.ts
# (private Shop order requests) — Pages Functions only, same three variables
# power both.
# CONSULTATION_TO_EMAIL: inbox that receives consultation inquiries and order-request alerts.
# CONSULTATION_FROM_EMAIL: optional; defaults to a Resend shared sending address
# if left blank. Set this once a sending domain is verified in Resend.
CONSULTATION_TO_EMAIL=
CONSULTATION_FROM_EMAIL=
